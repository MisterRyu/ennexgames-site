#!/bin/sh
# Interactive post-commit hook: ask before generating an implementation summary.

REPO_ROOT=$(git rev-parse --show-toplevel)
TITLE=$(git log -1 --pretty=%s)

# Skip if hook disabled via env
if [ "$SKIP_IMPL_HOOK" = "1" ]; then
  exit 0
fi

# Only prompt in interactive terminals
if [ -t 1 ]; then
  printf "Generate implementation summary for commit '%s'? [y/N] " "$TITLE"
  read ans
  case "$ans" in
    [Yy]* )
      if command -v pwsh >/dev/null 2>&1; then
        pwsh -NoProfile -ExecutionPolicy Bypass -File "$REPO_ROOT/scripts/generate-implementation-summary.ps1" -Title "$TITLE" -Notes "Auto-generated by interactive post-commit hook"
      elif command -v powershell >/dev/null 2>&1; then
        powershell -NoProfile -ExecutionPolicy Bypass -File "$REPO_ROOT/scripts/generate-implementation-summary.ps1" -Title "$TITLE" -Notes "Auto-generated by interactive post-commit hook"
      else
        echo "PowerShell not found — skipping generation."
      fi
      ;;
    * )
      echo "Skipping implementation summary generation."
      ;;
  esac
else
  echo "Non-interactive shell detected; skipping implementation summary generation."
fi
