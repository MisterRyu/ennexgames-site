#!/bin/sh
# Post-commit hook: generate an implementation summary using the helper script.
# This will run the PowerShell helper with the last commit subject as the title.

REPO_ROOT=$(git rev-parse --show-toplevel)
TITLE=$(git log -1 --pretty=%s)

# Skip if hook disabled via env
if [ "$SKIP_IMPL_HOOK" = "1" ]; then
  exit 0
fi

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "$REPO_ROOT/scripts/generate-implementation-summary.ps1" -Title "$TITLE" -Notes "Auto-generated by post-commit hook"
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "$REPO_ROOT/scripts/generate-implementation-summary.ps1" -Title "$TITLE" -Notes "Auto-generated by post-commit hook"
fi
